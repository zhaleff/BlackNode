[global]
    monitor = 0
    follow = none
    width = (0, 300)
    height = (0, 150)
    origin = top-center
    offset = "0x20"
    alignment = left
    vertical_alignment = center
    ellipsize = middle
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    icon_position = left
    min_icon_size = 36
    max_icon_size = 48
    icon_corner_radius = 6
    progress_bar = true
    progress_bar_height = 6
    progress_bar_min_width = 200
    progress_bar_max_width = 260
    progress_bar_corner_radius = 4
    progress_bar_corners = all
    progress_bar_frame_width = 0
    frame_width = 0
    separator_height = 0
    corner_radius = 10
    gap_size = 8
    line_height = 2
    notification_limit = 4
    idle_threshold = 120
    history_length = 50
    show_age_threshold = 60
    markup = full
    font = "JetBrains Mono Nerd Font Medium 10"
    format = "<b>%s</b>\n%b"
    word_wrap = yes
    sort = yes
    shrink = no
    indicate_hidden = yes
    sticky_history = yes
    ignore_newline = no
    show_indicators = no
    stack_duplicates = true
    always_run_script = true
    hide_duplicate_count = false
    ignore_dbusclose = false
    force_xwayland = false
    mouse_left_click = do_action
    mouse_middle_click = close_all
    mouse_right_click = close_current
    browser = firefox
    progress_bar_color = "{{colors.primary.default.hex}}"
    progress_bar_frame_color = "{{colors.surface.default.hex}}"

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "{{colors.surface.default.hex}}"
    foreground = "{{colors.on_surface.default.hex}}"
    highlight = "{{colors.primary.default.hex}}"
    timeout = 4

[urgency_normal]
    background = "{{colors.surface.default.hex}}"
    foreground = "{{colors.on_surface.default.hex}}"
    highlight = "{{colors.primary.default.hex}}"
    timeout = 6

[urgency_critical]
    background = "{{colors.surface.default.hex}}"
    foreground = "{{colors.error.default.hex}}"
    highlight = "{{colors.error.default.hex}}"
    timeout = 0

[shortcuts]
    close_notification = ctrl+space
    close_all_notifications = ctrl+shift+space
    history_pop = ctrl+grave
    context_menu = ctrl+shift+period

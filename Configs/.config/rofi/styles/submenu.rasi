@import "~/.config/rofi/colors.rasi"

configuration {
    font:                        "JetBrainsMono Nerd Font 13";
    show-icons:                  false;
}

window {
    width:                       380px;
    transparency:                "real";
    border-radius:               28px;
    background-color:            @surface;
    location:                    center;
    anchor:                      center;
}

mainbox {
    spacing:                     0px;
    padding:                     16px;
    orientation:                 vertical;
    children:                    [ "inputbar", "listview" ];
    background-color:            transparent;
}

inputbar {
    spacing:                     0px;
    padding:                     0px 0px 12px 0px;
    children:                    [ "entry" ];
    background-color:            transparent;
}

entry {
    background-color:            @surface-container-high;
    text-color:                  @on-surface;
    cursor:                      text;
    vertical-align:              0.5;
    placeholder:                 "    Search...";
    placeholder-color:           @on-surface-variant;
    padding:                     12px 16px;
    border-radius:               16px;
}

listview {
    enabled:                     true;
    columns:                     1;
    spacing:                     4px;
    padding:                     0px;
    cycle:                       true;
    lines:                       6;
    dynamic:                     true;
    scrollbar:                   false;
    layout:                      vertical;
    background-color:            transparent;
    text-color:                  @on-surface;
}

element {
    spacing:                     0px;
    padding:                     10px 14px;
    cursor:                      pointer;
    background-color:            transparent;
    text-color:                  @on-surface;
    border-radius:               14px;
}

element selected.normal {
    background-color:            @secondary-container;
    text-color:                  @on-secondary-container;
}

element-icon {
    size:                        28px;
    cursor:                      inherit;
    background-color:            transparent;
    text-color:                  inherit;
}

element-text {
    vertical-align:              0.5;
    horizontal-align:            0.0;
    cursor:                      inherit;
    background-color:            transparent;
    text-color:                  inherit;
    margin:                      0px 0px 0px 14px;
}

textbox {
    text-color:                  inherit;
    background-color:            inherit;
    vertical-align:              0.5;
    horizontal-align:            0.5;
}

@import "~/.cache/wallust/rofi.rasi"

configuration {
  modi: "drun,filebrowser,window,run";
  show-icons: true;
  display-drun: " ";
  display-run: " ";
  display-filebrowser: " ";
  display-window: " ";
  drun-display-format: "{name}";
  window-format: "{w}{t}";
  font: "JetBrainsMono Nerd Font 10";
  icon-theme: "Tela-circle-dracula";
}

window {
    height:                      416px;
    width:                       608px;
    transparency:                "real";
    fullscreen:                  false;
    border:                      1px;
    border-radius:               14px;
    background-color:            var(background);
    location:                    center;
    anchor:                      center;
    spacing:                     0px;
    padding:                     0px;
}

mainbox {
    enabled:                     true;
    spacing:                     0px;
    padding:                     0px;
    orientation:                 vertical;
    children:                    [ "inputbar", "listview" ];
    background-color:            transparent;
}

inputbar {
    enabled:                     true;
    spacing:                     10px;
    padding:                    16px 19px;
    children:                    [ "entry" ];
    background-color:            var(color4);
    border-radius:               14px;
    text-color:                  var(background);
}

entry {
    enabled:                     true;
    background-color:            transparent;
    text-color:                  var(background);
    cursor:                      text;
    placeholder:                 "Search...";
    placeholder-color:          rgba(0,0,0,0.5);
}

listview {
    enabled:                     true;
    spacing:                     0px;
    padding:                    13px 16px;
    columns:                     1;
    lines:                       6;
    cycle:                       true;
    dynamic:                     true;
    scrollbar:                   false;
    layout:                      vertical;
    background-color:            var(background);
    border-radius:               14px;
    text-color:                  var(foreground);
}

element {
    enabled:                     true;
    spacing:                     13px;
    padding:                    8px 16px;
    cursor:                      pointer;
    background-color:            transparent;
    text-color:                  var(foreground);
    border-radius:               10px;
}

element selected.normal {
    background-color:            var(color4);
    text-color:                  var(background);
}

element-icon {
    size:                        29px;
    cursor:                      inherit;
    background-color:            transparent;
    text-color:                  inherit;
}

element-text {
    vertical-align:              0.5;
    horizontal-align:            0.0;
    cursor:                      inherit;
    background-color:            transparent;
    text-color:                  inherit;
}

textbox {
    text-color:                  inherit;
    background-color:            inherit;
    vertical-align:              0.5;
    horizontal-align:            0.5;
}
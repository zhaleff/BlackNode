/* card-center */
@import "~/.cache/wallust/rofi.rasi"

configuration {
    modi:                        "drun,filebrowser,window,run";
    show-icons:                  true;
    display-drun:                " ";
    display-run:                 " ";
    display-filebrowser:         " ";
    display-window:              " ";
    drun-display-format:         "{name}";
    font:                        "JetBrainsMono Nerd Font 10";
    icon-theme:                  "Tela-circle-dracula";
}

window {
    width:                       750px;
    height:                      500px;
    transparency:                "real";
    border:                      0px;
    border-radius:               20px;
    background-color:            var(background);
    location:                    center;
    anchor:                      center;
}

mainbox {
    children:                    [ "sidebar", "listview" ];
    spacing:                     0px;
    padding:                     0px;
    orientation:                 horizontal;
    background-color:            transparent;
}

sidebar {
    expand:                      false;
    width:                       220px;
    background-color:            var(color4);
    border-radius:               20px 0px 0px 20px;
    orientation:                vertical;
    children:                    [ "inputbar", "mode-switcher" ];
    spacing:                     16px;
    padding:                     20px;
}

inputbar {
    children:                    [ "entry" ];
    background-color:            var(color0);
    border-radius:               12px;
    padding:                     4px;
}

entry {
    placeholder:                 "Search...";
    placeholder-color:           var(color7);
    font:                        "JetBrainsMono Nerd Font 10";
    text-color:                  var(foreground);
    background-color:            transparent;
    padding:                     10px 12px;
}

mode-switcher {
    orientation:                vertical;
    spacing:                     8px;
}

button {
    padding:                    12px 16px;
    border-radius:               12px;
    background-color:            transparent;
    text-color:                  var(foreground);
    font:                        "JetBrainsMono Nerd Font 10";
    horizontal-align:            0.5;
}

button selected {
    background-color:            var(color5);
    text-color:                  var(background);
}

listview {
    enabled:                     true;
    columns:                     1;
    lines:                       8;
    layout:                      vertical;
    spacing:                     8px;
    padding:                     20px;
    background-color:            var(background);
    border-radius:               0px 20px 20px 0px;
    text-color:                  var(foreground);
}

element {
    orientation:                horizontal;
    padding:                    12px 16px;
    cursor:                      pointer;
    background-color:            transparent;
    text-color:                  var(foreground);
    border-radius:               12px;
}

element selected {
    background-color:            var(color4);
    text-color:                  var(background);
}

element-icon {
    size:                        32px;
}

element-text {
    font:                        "JetBrainsMono Nerd Font 10";
    text-color:                  var(foreground);
    vertical-align:              0.5;
}
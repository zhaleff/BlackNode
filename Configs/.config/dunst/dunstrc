[global]
    monitor = 0
    follow = none
    width = (300, 380)
    height = (0, 150)
    origin = top-center
    offset = "0x20"
    alignment = left
    vertical_alignment = center
    ellipsize = middle
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 12
    icon_position = left
    min_icon_size = 40
    max_icon_size = 48
    icon_corner_radius = 24
    progress_bar = true
    progress_bar_height = 4
    progress_bar_min_width = 200
    progress_bar_max_width = 280
    progress_bar_corner_radius = 4
    progress_bar_corners = all
    progress_bar_frame_width = 0
    frame_width = 0
    separator_height = 0
    corner_radius = 24
    gap_size = 10
    line_height = 3
    notification_limit = 4
    idle_threshold = 120
    history_length = 50
    show_age_threshold = 60
    markup = full
    font = "JetBrains Mono Nerd Font Medium 10"
    format = "<b>%s</b>\n%b"
    word_wrap = yes
    sort = yes
    shrink = no
    indicate_hidden = yes
    sticky_history = yes
    ignore_newline = no
    show_indicators = no
    stack_duplicates = true
    always_run_script = true
    hide_duplicate_count = false
    ignore_dbusclose = false
    force_xwayland = false
    mouse_left_click = do_action
    mouse_middle_click = close_all
    mouse_right_click = close_current
    browser = firefox
    progress_bar_color = "#94d5a8"
    progress_bar_frame_color = "#0f1511"

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#0f1511"
    foreground = "#dfe4dd"
    highlight = "#94d5a8"
    timeout = 4

[urgency_normal]
    background = "#0f1511"
    foreground = "#dfe4dd"
    highlight = "#94d5a8"
    timeout = 6

[urgency_critical]
    background = "#0f1511"
    foreground = "#ffb4ab"
    highlight = "#ffb4ab"
    timeout = 0

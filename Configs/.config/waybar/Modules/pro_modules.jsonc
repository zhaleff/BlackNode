{
  "custom/target_pro": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/Scripts/hacking/target_manager.rb",
    "on-click": "~/.config/waybar/Scripts/hacking/target_manager.rb --menu",
    "interval": 2
  },
  "custom/vpn_pro": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/Scripts/network/vpn_status.rb",
    "interval": 5
  },
  "custom/notes_pro": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/Scripts/utils/quick_notes.rb",
    "on-click": "~/.config/waybar/Scripts/utils/quick_notes.rb --menu",
    "interval": 5
  },
  "custom/media_pro": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/Scripts/music/media_dashboard.rb",
    "on-click": "~/.config/waybar/Scripts/music/media_dashboard.rb --dashboard",
    "interval": 2
  }
}

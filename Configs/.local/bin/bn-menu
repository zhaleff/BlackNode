        "ï’¼  System")        "$SCRIPTS/system/menu.sh" ;;
        "َ°“ƒ  Audio")         "$SCRIPTS/audio/menu.sh" ;;
        "َ°چ¹  Display")       "$SCRIPTS/display/menu.sh" ;;

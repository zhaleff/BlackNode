        "َ°„‰  Waybar")        "$SCRIPTS/waybar/menu.sh" ;;
        "َ°‘گ  Reload")        "$SCRIPTS/reload/menu.sh" ;;
        "َ±–«  Services")      "$SCRIPTS/services/menu.sh" ;;
        "َ°ŒŒ  Theme")         "$SCRIPTS/theme/menu.sh" ;;
        "ï‹œ  Profiles")      "$HOME/.config/rofi/scripts/profiles.sh" ;;

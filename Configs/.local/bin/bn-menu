        "َ°‘گ  Reload" \
        "َ±–«  Services" \
        "َ°ŒŒ  Theme" \
        "ï‹œ  Profiles" \
        "َ±‘€  Pomodoro" \
        "َ°‹¼  About" \
        "َ°چƒ  Session" \
        "َ°‚¯  Bluetooth" \
